<div id="rapid-tests-widget">
    <subform path="configuration/pih/subforms/rapid-tests-widget.css"/>
    <subform path="configuration/pih/subforms/rapid-tests-widget.js"/>
    <div class="boundary"></div>
    <div class="bordered-section">
        <ifMode mode="VIEW" include="false">
            <lookup complexExpression="#set( $hivRtResult = $fn.latestObsBeforeCurrentEncounter('CIEL:163722', false) )"/>
            <includeIf velocityTest="($hivRtResult) ">
                <lookup complexExpression="#set( $hivAnsConceptUuid = $hivRtResult.valueCoded.uuid )"/>
                <includeIf velocityTest="$hivAnsConceptUuid == $fn.getConcept('CIEL:703').uuid">
                    <lookup complexExpression="#set($hivPositiveTest = 'true')"/>
                </includeIf>
            </includeIf>
        </ifMode>

        <!-- HIV test construct !-->
        <obsgroup groupingConceptId="PIH:11522">
            <p class="list-inline">
                <label>
                    <uimessage code="HIV rapid test"/>
                </label>
                <excludeIf velocityTest="($hivRtResult) &amp;&amp; ($hivAnsConceptUuid) &amp;&amp; ($hivPositiveTest)">
                    <obs id="hiv-rapid-test" conceptId="CIEL:163722" style="radio"
                         answerConceptIds="CIEL:703,CIEL:664,CIEL:1138,CIEL:160737"
                         answerLabels="Positive,Negative,Indeterminate,Not performed">
                        <controls>
                            <when value="CIEL:160737" thenDisplay="#hrt-reason-not-done" />
                        </controls>
                    </obs>
                </excludeIf>
                <includeIf velocityTest="($hivRtResult)">
                    <includeIf velocityTest="$hivAnsConceptUuid == $fn.getConcept('CIEL:703').uuid">
                        <label class="bolder-blue">Latest test date: </label>
                        <span class="light-blue"><lookup complexExpression="$hivRtResult.obsDatetime"/></span>
                        <label class="bolder-blue">&nbsp;&nbsp;&nbsp;Result: </label>
                        <span class="light-blue">
                            <uimessage code="pihcore.positive"/>
                        </span>
                    </includeIf>
                    <includeIf velocityTest="$hivAnsConceptUuid != $fn.getConcept('CIEL:703').uuid">
                        <p class="list-inline">
                            <label></label>
                            <label class="bolder-blue">Latest test date: </label>
                            <span class="light-blue"><lookup complexExpression="$hivRtResult.obsDatetime"/></span>
                            <label class="bolder-blue">&nbsp;&nbsp;&nbsp;Result: </label>
                            <span class="light-blue">
                                <includeIf velocityTest="$hivAnsConceptUuid == $fn.getConcept('CIEL:664').uuid">
                                    <uimessage code="pihcore.negative"/>
                                </includeIf>
                                <includeIf velocityTest="$hivAnsConceptUuid == $fn.getConcept('CIEL:1138').uuid">
                                    <uimessage code="pihcore.indeterminate"/>
                                </includeIf>
                                <includeIf velocityTest="$hivAnsConceptUuid == $fn.getConcept('CIEL:160737').uuid">
                                    <uimessage code="pihcore.notPerformed"/>
                                </includeIf>
                            </span>
                        </p>
                    </includeIf>
                </includeIf>
            </p>
            <excludeIf velocityTest="($hivRtResult) &amp;&amp; ($hivAnsConceptUuid) &amp;&amp; ($hivPositiveTest)">
                <div id="hrt-reason-not-done" class="indented">
                    <p class="list-inline">
                        <label>
                            <uimessage code="Reason not performed"/>
                        </label>
                        <obs style="radio"
                             conceptId="CIEL:165182"
                             answerConceptIds="CIEL:165183,CIEL:167156,CIEL:5622"
                             answerCodes="No test kit,Patient refused,other"/>
                    </p>
                </div>
            </excludeIf>
        </obsgroup>
    </div>
    <div class="boundary"></div>
    <div class="bordered-section">
        <obsgroup groupingConceptId="PIH:11523">
            <p class="list-inline">
                <label>
                    <uimessage code="Syphillis rapid test"/>
                </label>
                <obs id="syphillis-rapid-test" conceptId="CIEL:165303" style="radio"
                     answerConceptIds="CIEL:1228,CIEL:1229,CIEL:1138,CIEL:160737"
                     answerLabels="Positive,Negative,Indeterminate,Not performed">
                    <controls>
                        <when value="CIEL:160737" thenDisplay="#syph-reason-not-done" />
                    </controls>
                </obs>
            </p>

            <div id="syph-reason-not-done" class="indented">
                <p class="list-inline">
                    <label>
                        <uimessage code="Reason not performed"/>
                    </label>
                    <obs style="radio"
                         conceptId="CIEL:165182"
                         answerConceptIds="CIEL:165183,CIEL:167156,CIEL:5622"
                         answerCodes="No test kit,Patient refused,other"/>
                </p>
            </div>
        </obsgroup>
        <ifMode mode="VIEW" include="false">
            <lookup complexExpression="#set( $syphillisResult = $fn.latestObsBeforeCurrentEncounter('CIEL:165303', false) )"/>
            <includeIf velocityTest="($syphillisResult) ">
                <p class="list-inline">
                    <label></label>
                    <label class="bolder-blue">Latest test date: </label>
                    <span class="light-blue"><lookup complexExpression="$syphillisResult.obsDatetime"/></span>
                    <label class="bolder-blue">&nbsp;&nbsp;&nbsp;Result: </label>
                    <span class="light-blue">
                        <lookup complexExpression="#set( $ansConceptUuid = $syphillisResult.valueCoded.uuid )"/>
                        <includeIf velocityTest="$ansConceptUuid == $fn.getConcept('CIEL:1228').uuid">
                            <uimessage code="pihcore.positive"/>
                        </includeIf>
                        <includeIf velocityTest="$ansConceptUuid == $fn.getConcept('CIEL:1229').uuid">
                            <uimessage code="pihcore.negative"/>
                        </includeIf>
                        <includeIf velocityTest="$ansConceptUuid == $fn.getConcept('CIEL:1138').uuid">
                            <uimessage code="pihcore.indeterminate"/>
                        </includeIf>
                        <includeIf velocityTest="$ansConceptUuid == $fn.getConcept('CIEL:160737').uuid">
                            <uimessage code="pihcore.notPerformed"/>
                        </includeIf>
                    </span>
                </p>
            </includeIf>
        </ifMode>
    </div>
    <div class="boundary"></div>
    <div class="bordered-section">
        <p class="list-inline">
            <label>
                <uimessage code="Hepatitis B (HbsAb)"/>
            </label>
            <obs id="HBsAg" style="radio"
                 conceptId="CIEL:159430"
                 answerConceptIds="CIEL:703,CIEL:664,CIEL:1138"/>
        </p>
        <ifMode mode="VIEW" include="false">
            <lookup complexExpression="#set( $hbsAbResult = $fn.latestObsBeforeCurrentEncounter('CIEL:159430', false) )"/>
            <includeIf velocityTest="($hbsAbResult) ">
                <p class="list-inline">
                    <label></label>
                    <label class="bolder-blue">Latest test date: </label>
                    <span class="light-blue"><lookup complexExpression="$hbsAbResult.obsDatetime"/></span>
                    <label class="bolder-blue">&nbsp;&nbsp;&nbsp;Result: </label>
                    <span class="light-blue">
                        <lookup complexExpression="#set( $hbsAnsConceptUuid = $hbsAbResult.valueCoded.uuid )"/>
                        <includeIf velocityTest="$hbsAnsConceptUuid == $fn.getConcept('CIEL:703').uuid">
                            <uimessage code="pihcore.positive"/>
                        </includeIf>
                        <includeIf velocityTest="$hbsAnsConceptUuid == $fn.getConcept('CIEL:664').uuid">
                            <uimessage code="pihcore.negative"/>
                        </includeIf>
                        <includeIf velocityTest="$hbsAnsConceptUuid == $fn.getConcept('CIEL:1138').uuid">
                            <uimessage code="pihcore.indeterminate"/>
                        </includeIf>
                    </span>
                </p>
            </includeIf>
        </ifMode>
    </div>
    <div class="boundary"></div>
</div>