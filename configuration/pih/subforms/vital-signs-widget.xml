<div id="vital-signs-widget">
    <subform path="configuration/pih/subforms/vital-signs-widget.css"/>
    <subform path="configuration/pih/subforms/vital-signs-widget.js"/>

    <ifMode mode="VIEW" include="false">
        <div class="vitals six-columns">
            <div class="vitals-cell">
                <div class="colorCodingValue">
                    <label>
                        <uimessage code="mirebalais.vitals.bloodPressure.short.title"/>
                    </label>
                    <span class="small">
                        <span class="append-to-value left">
                            <obs conceptId="CIEL:5085" id="bp_systolic" class="vitals-values"/>
                        </span>
                        <span class="append-to-value left">/</span>
                        <span class="append-to-value left">
                            <obs conceptId="CIEL:5086" id="bp_diastolic" class="vitals-values"/>
                        </span>
                        <ifMode mode="VIEW" include="false">
                        <br></br>
                        </ifMode>
                        <span class="append-to-value">mm/Hg</span>
                    </span>
                </div>
            </div>

            <div>
                <div class="colorCodingValue">
                    <label>
                        <uimessage code="mirebalais.vitals.short.heartRate.title"/>
                    </label>
                    <span class="small">
                        <obs conceptId="CIEL:5087" id="heart_rate" class="vitals-values"
                             showUnits="emr.units.perMinute" unitsCssClass="append-to-value"/>
                    </span>
                </div>
            </div>

            <div>
                <div class="colorCodingValue">
                <label>
                    <uimessage code="mirebalais.vitals.respiratoryRate.short.title"/>
                </label>
                <span class="small">
                    <obs conceptId="CIEL:5242" id="respiratory_rate" class="vitals-values"
                         showUnits="emr.units.perMinute" unitsCssClass="append-to-value"/>
                </span>
                </div>
            </div>

            <div>
                <div class="colorCodingValue">
                <label>
                    <uimessage code="Temp"/>
                </label>
                <span class="small">
                    <obs conceptId="CIEL:5088" id="temperature_c" class="vitals-values"
                         showUnits="emr.units.degreesCelsius" unitsCssClass="append-to-value"/>
                </span>
                </div>
            </div>

            <div>
                <div class="colorCodingValue">
                <label>
                    <uimessage code="o2Sat"/>
                </label>
                <span class="small">
                    <obs conceptId="CIEL:5092" id="o2_sat" class="vitals-values"
                         showUnits="emr.units.percent" unitsCssClass="append-to-value"/>
                </span>
                </div>
            </div>

            <div id="fhrDiv" style="vertical-align: top;">
                <div class="colorCodingValue" style="display: block;">
                    <label>
                        <uimessage code="FHR"/>
                    </label>
                    <span class="small">
                        <obs conceptId="CIEL:1440" id="fhr" class="vitals-values"
                             showUnits="true" unitsCssClass="append-to-value"/>
                    </span>
                </div>
                <div class="colorCodingValue">
                    <label>
                        <uimessage code="Second FHR"/>
                    </label>
                    <span class="small">
                        <obs conceptId="PIH:21416" id="fhr_second" class="vitals-values"
                             showUnits="true" unitsCssClass="append-to-value"/>
                    </span>
                </div>
            </div>
        </div>
    </ifMode>

    <ifMode mode="VIEW" include="true">
        <style>
            #inpatient-vitals-form fieldset h3 {
                font-size: 1em;
                width: 200px;
                <!-- display: inline-block; -->
                margin: 0px;
                margin-right: 10px;
                color: #3E3E3E;
                vertical-align: top;
            }
        </style>
        <div>
            <fieldset>
                <h3>
                    <uimessage code="mirebalais.vitals.bloodPressure.title"/>
                </h3>
                <p class="left">
                    <obs conceptId="CIEL:5085" id="bp_systolic" class="vitals-values"/>
                </p>
                <p class="left">
                    /
                </p>
                <p class="left">
                    <obs conceptId="CIEL:5086" id="bp_diastolic" class="vitals-values"/>
                </p>
                <p class="left">mm/Hg</p>
            </fieldset>

            <fieldset>
                <h3>
                    <uimessage code="mirebalais.vitals.heartRate.title"/>
                </h3>
                <p>
                    <obs conceptId="CIEL:5087" id="heart_rate" class="vitals-values"
                         showUnits="emr.units.perMinute" unitsCssClass="append-to-value"/>
                </p>
            </fieldset>

            <fieldset>
                <h3>
                    <uimessage code="mirebalais.vitals.respiratoryRate.title"/>
                </h3>
                <p>
                    <obs conceptId="CIEL:5242" id="respiratory_rate" class="vitals-values"
                         showUnits="emr.units.perMinute" unitsCssClass="append-to-value"/>
                </p>
            </fieldset>

            <fieldset>
                <h3>
                    <uimessage code="Temp"/>
                </h3>
                <p>
                    <obs conceptId="CIEL:5088" id="temperature_c" class="vitals-values"
                         showUnits="emr.units.degreesCelsius" unitsCssClass="append-to-value"/>
                </p>
            </fieldset>

            <fieldset>
                <h3>
                    <uimessage code="o2Sat"/>
                </h3>
                <p>
                    <obs conceptId="CIEL:5092" id="o2_sat" class="vitals-values"
                         showUnits="emr.units.percent" unitsCssClass="append-to-value"/>
                </p>
            </fieldset>

            <fieldset>
                <h3>
                    <uimessage code="FHR"/>
                </h3>
                <p>
                    <obs conceptId="CIEL:1440" id="fhr" class="vitals-values"
                         showUnits="true" unitsCssClass="append-to-value"/>
                </p>
            </fieldset>
            <fieldset>
                <h3>
                    <uimessage code="Second FHR"/>
                </h3>
                <p>
                    <obs conceptId="PIH:21416" id="fhr_second" class="vitals-values"
                         showUnits="true" unitsCssClass="append-to-value"/>
                </p>
            </fieldset>
        </div>
    </ifMode>

    <div id="confirmMsg">
        <span>Contact doctor for early intervention if patient triggers one red, one orange or two yellow scores at any one time.</span>
        <br/>
        <obs id="contactDr" style="checkbox" conceptId="PIH:20925" answerConceptId="CIEL:1065" answerLabel="" labelText="Confirmed doctor contacted"></obs>
    </div>
</div>