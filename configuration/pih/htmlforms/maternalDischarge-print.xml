<!--
    Print-only rendering of the Maternal Discharge encounter (encounterType 2110a810-db62-4914-ba95-604b96010164).

    This is NOT a data-entry form: it is rendered in VIEW mode via
    /htmlformentryui/htmlform/viewEncounterWithHtmlForm/getAsHtml.action?...&definitionUiResource=...maternalDischarge-print.xml
    and printed by the "Print form" action on the visit page (see encounterTypeConfig.js -> printFormUrl).

    It reads the same concepts captured by maternalDischarge.xml so the printout reflects the stored data,
    laid out to match the paper "Maternity Discharge Form".
-->
<htmlform id="maternal-discharge-print"
          formUuid="a5377e3a-228e-4186-b6f5-a86d0ba0d136"
          formName="Maternal Discharge (Print)"
          formEncounterType="2110a810-db62-4914-ba95-604b96010164"
          formVersion="1.0">

    <style type="text/css">

        #maternity-discharge-print {
            font-size: 0.95em;
            line-height: 1.6em;
            color: #000;
        }

        #maternity-discharge-print .form-header {
            display: table;
            width: 100%;
            border-bottom: 2px solid #000;
            padding-bottom: 8px;
            margin-bottom: 12px;
        }

        #maternity-discharge-print .form-header > div {
            display: table-cell;
            vertical-align: middle;
        }

        #maternity-discharge-print .form-header .logo-left img {
            height: 55px;
            object-fit: contain; /* Ensures the image isn't stretched if the aspect ratio is different */
        }

        #maternity-discharge-print .form-header .logo-right {
            text-align: right;
        }

        #maternity-discharge-print .form-header .logo-right img {
            height: 45px;
            width: auto;  /* Maintains aspect ratio */
        }

        #maternity-discharge-print .form-header .form-title {
            text-align: center;
            font-size: 1.3em;
            font-weight: bold;
            text-transform: uppercase;
        }

        #maternity-discharge-print h3 {
            font-size: 1.05em;
            font-weight: bold;
            border-bottom: 1px solid #999;
            margin: 14px 0px 6px 0px;
            padding-bottom: 2px;
        }

        #maternity-discharge-print .field {
            display: inline-block;
            margin-right: 25px;
        }

        #maternity-discharge-print .field label,
        #maternity-discharge-print .block label {
            font-weight: bold;
            margin-right: 5px;
        }

        #maternity-discharge-print .block {
            margin-bottom: 8px;
        }

        #maternity-discharge-print .block .value,
        #maternity-discharge-print .block .obs-value {
            display: block;
            min-height: 1.4em;
            border-bottom: 1px dotted #bbb;
            padding: 2px 0px;
        }

        /* inline block: keep the label and its value/widget (obs or diagnoses) on the same line */
        #maternity-discharge-print .block.inline {
            display: flex;
            align-items: baseline;
        }

        #maternity-discharge-print .block.inline .obs-value {
            display: inline-block;
            min-height: 0;
            border-bottom: none;
        }

        #maternity-discharge-print .signature {
            margin-top: 35px;
        }

        #maternity-discharge-print .signature .field {
            margin-right: 45px;
        }

        #maternity-discharge-print .print-form-datestamps {
            margin-top: 25px;
            font-size: 0.8em;
            color: #666;
        }

        /* the diagnosis and drug-order widgets render their own controls; keep them compact and read-only looking */
        #maternity-discharge-print .order-field-widget,
        #maternity-discharge-print select,
        #maternity-discharge-print input {
            border: none;
            background: transparent;
        }
        /* Hide the label for the drug field in view mode */

        .orderwidget-history-section .order-field-label.order-drug .orderwidget-section-header .order-action{
            display:none;
        }

        /*  Add a colon after the Dose label in view mode */
        .orderwidget-history-section .order-field-label.order-dose:after {
            content: ": ";
            white-space: pre;
        }
        .order-field.order-field-hidden {
            display:none;
        }
        div#disposition > label {
            margin-right: 8px; /* Adjust the width of the space as needed */
        }
        p.side-by-side > strong {
            display: none;
        }

        div#appointment-datetime-field {
            display: flex;
            align-items: center; /* Vertically centers the label and the date text */
            gap: 10px;           /* Adds space between the label and the date */
        }

        /* Optional: Removing the default bottom margin from the label for better alignment */
        div#appointment-datetime-field > label {
            margin-bottom: 0;
        }

        p.date-one-line {
            gap: 10px; /* Adjust this value for the amount of space you want */
        }
        /* 1. Make the container a flexbox to align children horizontally */
        div.orderwidget-order-history-item {
            display: flex;
            flex-wrap: wrap; /* Allows fields to wrap to the next line if the screen is too narrow */
            align-items: baseline; /* Aligns text nicely across different fields */
            gap: 20px; /* This adds the "couple of spaces" between each field */
        }

        /* 2. Ensure the direct child wrappers are also inline */
        div.orderwidget-order-history-item > div {
            display: inline-block;
        }

        /* 3. Optional: If you want to hide the labels to save more space */
        /*
        div.orderwidget-order-history-item .order-field-label {
            display: none;
        }
        
        */
        /* Hide the section if it contains the "no-orders" div */
        .orderwidget-existing-order-section:has(.orderwidget-section-no-orders) {
            display: none;
        }
        /* Hide New Orders label */
        .orderwidget-new-order-section > .orderwidget-section-header {
            display: none;
        }

    </style>

    <div id="maternity-discharge-print">

        <!-- ===================== Header ===================== -->
        <div class="form-header">
            <div class="logo-left">
                <img src="/openmrs/ms/uiframework/resource/file/configuration/pih/htmlforms/images/moh-sierra-leone-seal.png"
                     alt="Ministry of Health - Government of Sierra Leone"/>
            </div>
            <div class="form-title">
                Maternity Discharge Form
            </div>
            <div class="logo-right">
                <img src="/openmrs/ms/uiframework/resource/file/configuration/pih/htmlforms/images/pih-sierra-leone-logo.png"
                     alt="Partners In Health - Sierra Leone"/>
            </div>
        </div>

        <!-- ===================== Patient Details ===================== -->
        <h3>Patient Details</h3>

        <p>
            <span class="field">
                <label>Name:</label>
                <lookup class="value" expression="patient.personName"/>
            </span>
            <span class="field">
                <label>Age:</label>
                <lookup class="value" expression="patient.age"/>
            </span>
            <span class="field">
                <label>EMR ID:</label>
                <lookup class="value" complexExpression="$!{patient.patientIdentifier.identifier}"/>
            </span>
        </p>
        <p>
            <span class="field">
                <label>Address:</label>
                <lookup class="value" complexExpression="$!{patient.personAddress.address1} $!{patient.personAddress.cityVillage}"/>
            </span>
            <span class="field">
                <label>Chiefdom:</label>
                <lookup class="value" complexExpression="$!{patient.personAddress.stateProvince}"/>
            </span>
            <span class="field">
                <label>District:</label>
                <lookup class="value" complexExpression="$!{patient.personAddress.countyDistrict}"/>
            </span>
        </p>
        <p>
            <span class="field">
                <label>Discharge Ward:</label>
                <lookup class="value" expression="encounter.location"/>
            </span>
            <span class="field">
                <label>Date of Admission:</label>
                <lookup class="value"
                        complexExpression="#set( $admission = $fn.latestObsBeforeCurrentEncounter('CIEL:1640', true) )#if( $admission )$ui.format($admission.valueDatetime)#end"/>
            </span>
            <span class="field">
                <label>Date of Discharge:</label>
                <lookup class="value" expression="encounter.encounterDatetime" format="dd MMM yyyy"/>
            </span>
        </p>

        <!-- ===================== Diagnoses and Medications ===================== -->
        <h3>Diagnoses and Medications</h3>

        <div class="block inline">
            <label>Diagnoses:</label>
            <encounterDiagnosesByObs/>
        </div>

        <div class="block">
            <label>Discharge Medications:</label>
            <subform path="configuration/pih/subforms/drug-order-widget.xml"/>
        </div>

        <!-- ===================== Summary ===================== -->
        <h3>Summary</h3>

        <div class="block inline">
            <label>Clinical History:</label>
            <obs class="obs-value" conceptId="CIEL:160221" style="textarea"/>
        </div>

        <div class="block inline">
            <label>Summary of investigation:</label>
            <obs class="obs-value" conceptId="CIEL:165399" style="textarea"/>
        </div>

        <div class="block inline">
            <label>Summary of management in the hospital:</label>
            <!-- NOTE: the capture form (maternalDischarge.xml) currently stores both the investigation and
                 management summaries under CIEL:165399, so only one stored value exists for these two fields. -->
            <obs class="obs-value" conceptId="CIEL:165399" style="textarea"/>
        </div>

        <!-- ===================== Discharge and Follow Up ===================== -->
        <h3>Discharge and Follow Up</h3>
        <div id="disposition">
            <encounterDisposition required="true" id="encounter-disposition" />
        </div>
        <div class="block inline">
            <label>Discharge recommendations:</label>
            <obs class="obs-value" conceptId="PIH:DISPOSITION COMMENTS" style="textarea"/>
        </div>

        <scheduleAppointment optional="true" type="scheduled"
                        locationTag="Appointment Location"
                        appointmentUuidConcept="PIH:Appointment uuid"
                        specialities="maternal,other"
                        sortServicesBy="specialityOrder,serviceName"/>

        <div class="signature">
            <span class="field">
                <label>Provider Name:</label>
                <!-- $encounter.provider (deprecated) only returns a provider recorded under the Unknown role;
                     this encounter records its provider under a specific role, so render the tag bound to that
                     same role (encounterProviderAndRole shows the provider name read-only in VIEW mode). -->
                <encounterProviderAndRole encounterRole="4f10ad1a-ec49-48df-98c7-1391c6ac7f05"/>
            </span>
            <span class="field">
                <label>Date:</label>
                <lookup expression="encounter.encounterDatetime" format="dd MMM yyyy"/>
            </span>
        </div>

    </div>

</htmlform>
