                </template>
                <render concept="CIEL:228"    name="Haemorrhage"/>
                <render concept="CIEL:117399" name="Hypertensive disorder"/>
                <render concept="CIEL:145047" name="Infection"/>
                <render concept="CIEL:116128" name="Malaria"/>
                <render concept="CIEL:115491" name="Multiple gestation" />
                <render concept="CIEL:111633" name="UTI"/>
                <render concept="CIEL:117703" name="Sickle-cell anaemia"/>
                <render concept="CIEL:113599" name="Post-date pregnancy"/>
                <render concept="CIEL:112416" name="Threatened abortion"/>
                <render concept="CIEL:118256" name="Foetal distress"/>

                <render concept="CIEL:5622" name="other"/>
