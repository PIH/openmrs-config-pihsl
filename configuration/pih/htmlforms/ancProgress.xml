    <section id="gen-exam" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="General exam">
        <div class="section-container two-columns exam">
            <div>
                <repeat>
                    <template>
                        <obs class="{normAb}" style="checkbox"
                             conceptId="PIH:GENERAL EXAM FINDINGS"
                             answerConceptId="{answer}"
                             answerCode="{comment}"/>
                    </template>
                    <render normAb="normalObs"   answer="CIEL:1115"   comment="normal" />
                    <render normAb="abnormalObs" answer="CIEL:460"    comment="Oedema" />
                    <render normAb="abnormalObs" answer="CIEL:136443" comment="Jaundice"/>
                    <render normAb="abnormalObs" answer="CIEL:5245"   comment="Pale"/>
                </repeat>

                <p>
                    <obs class="abnormalObs" conceptId="PIH:GENERAL EXAM FINDINGS"
                         answerConceptId="PIH:OTHER NON-CODED" style="checkbox" showCommentField="true"
                         commentFieldLabel="" />
                </p>
            </div>

            <div>
                <p class="comment-label">
                    <uimessage code="pihcore.exam.comment"/>
                </p>

                <p class="comment-field">
                    <p>
                        <obs conceptId="CIEL:163042" rows="5" cols="45" id="general-exam-comments"/>
                    </p>
                </p>
            </div>
        </div>
    </section>

    <section id="ob-exam" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="pihcore.exam.obstetrical_exam.title">

        <div class="section-container">
            <div class="four-columns">
                <div>
                    <p class="side-by-side">
                        <label>
                            <uimessage code="Previous abdominal scar" />
                        </label>
                        <br/>
                        <obs id="ab-scar" conceptId="CIEL:166893" style="radio"
                             answerConceptIds="CIEL:1065,CIEL:1066"
                             answerCodes="yes,no">
                            <controls>
                                <when value="CIEL:1065" thenDisplay="#ab-scar-details"/>
                            </controls>
                        </obs>
                    </p>
                </div>
                <div>
                    <label>
                        <uimessage code="pihcore.sympFundalHt"/>
                    </label>
                    <p class="narrow">
                        <obs conceptId="CIEL:1439" showUnits="true"/>
                    </p>
                </div>
                <div>
                    <p>
                        <obsgroup groupingConceptId="PIH:Visit Diagnoses" showIfEmpty="false">
                            <obs id="twins" conceptId="PIH:DIAGNOSIS" style="checkbox"
                                 answerConceptId="CIEL:115491" answerCode="twins or triplets"/>
                        </obsgroup>
                    </p>
                </div>
                <div>
                    <label>
                        <uimessage code="Number of foetuses"/>
                    </label>
                    <p class="narrow">
                        <obs conceptId="PIH:21404" />
                    </p>
                </div>
            </div>

            <div id="ab-scar-details" class="two-columns">
                <div>
                    <label>
                        <uimessage code="# of previous c-sections"/>
                    </label>
                    <obs conceptId="CIEL:160081"/>
                    <br/>
                </div>

                <div>
                    <label>
                        <uimessage code="Description of scar"/>
                    </label>
                    <obs conceptId="CIEL:168244"/>
                </div>
            </div>

            <style>
                h6 {text-align: center;}
            </style>

            <repeat with="['1'],['2'],['3']">
                <span id="fetus-{0}" class="fetus">
                    <obsgroup groupingConceptId="CIEL:165381" showIfEmpty="false">
                        <h6>~~~~~~~~~~~~~ Foetus {0} ~~~~~~~~~~~~~</h6>

                        <div class="two-columns">
                            <div>
                                <label>
                                    <uimessage code="pihcore.fetalHeartRate"/> (FHR)
                                </label>
                                <p class="narrow">
                                    <obs id="fetus-hr-{0}" conceptId="CIEL:1440"
                                         showUnits="true"/>
                                </p>

                                <p class="side-by-side">
                                    <label>
                                        <uimessage code="pihcore.fetalHeartRate"/> (FHR)
                                        method
                                    </label>
                                    <br/>
                                    <obs conceptId="CIEL:168715" id="fetal_hr_method-{0}" style="radio"
                                         answerConceptIds="CIEL:168716,CIEL:168717,CIEL:168718,CIEL:168719,CIEL:168720,CIEL:5622"
                                         answerCodes="Pinard,Doppler,Moyo,Janitri,CTG,other"/>
                                </p>

                                <p class="side-by-side">
                                    <label>
                                        <uimessage code="pihcore.fetalPresentation"/>
                                    </label>
                                    <br/>
                                    <obs id="fetus-presentation-{0}"
                                         conceptId="CIEL:160090" style="radio"
                                         answerSeparator="&lt;br /&gt;">
                                        <controls>
                                            <when value="CIEL:5622" thenDisplay="#other-presentation-{0}"/>
                                        </controls>
                                    </obs>
                                </p>
                                <div id="other-presentation-{0}">
                                    <label>
                                        <uimessage code="zl.ifOtherSpecify"/>
                                    </label>
                                    <obs conceptId="PIH:14414"/>
                                </div>
                            </div>

                            <div>
                                <p class="side-by-side">
                                    <label>
                                        <uimessage code="pihcore.fetalPosition"/>
                                    </label>
                                    <br/>
                                    <obs id="fetus-position-{0}" style="radio"
                                         conceptId="CIEL:163749" answerConceptIds="CIEL:5141,CIEL:5139"/>
                                </p>

                                <p class="side-by-side">
                                    <label>
                                        <uimessage code="Obstetric ultrasound findings"/>
                                    </label>
                                    <br/>
                                    <obs id="ob-us={0}" conceptId="PIH:21412" style="radio"
                                         answerConceptIds="CIEL:146922,CIEL:160091,CIEL:112259,CIEL:5622"
                                         answerSeparator="&lt;br /&gt;" >
                                        <controls>
                                            <when value="CIEL:5622" thenDisplay="#other-ob-us-find-{0}"/>
                                        </controls>
                                    </obs>

                                    <div id="other-ob-us-find-{0}">
                                        <label>
                                            <uimessage code="if other obstetrical u/s finding, specify"/>
                                        </label>
                                        <obs conceptId="PIH:7018" style="text" />
                                    </div>
                                </p>

                                <p class="side-by-side">
                                    <label>
                                        <uimessage code="Placenta location"/>
                                    </label>
                                    <br/>
                                    <obs id="placenta-location-{0}"
                                         conceptId="CIEL:165296" style="radio"
                                         answerConceptIds="CIEL:540,CIEL:541,CIEL:165298,CIEL:165297,CIEL:114127"
                                         answerCodes="anterior,posterior,fundal,low-lying,placenta previa"/>
                                </p>
                            </div>
                        </div>
                    </obsgroup>
                </span>
            </repeat>
            <button id="show-more-fetus-button" type="button" style="display:none">
                <uimessage code="pihcore.showMore"/>
            </button>
            <button id="show-less-fetus-button" type="button" style="display:none">
                <uimessage code="pihcore.showLess"/>
            </button>

            <hr/>
            <div class="two-columns">
                <div>
                    <p class="side-by-side">
                        <label>
                            <uimessage code="Uterine contraction (UC)"/>
                        </label>
                        <obs conceptId="CIEL:163750" style="radio"
                             answerConceptIds="CIEL:163747,CIEL:163748"
                             answerCodes="absent,present" />
                    </p>

                    <p class="side-by-side">
                        <label>
                            <uimessage code="Induced labor" />
                        </label>
                        <obs id="induced" conceptId="CIEL:151750" style="radio"
                             answerConceptIds="CIEL:1065,CIEL:1066"
                             answerCodes="yes,no"/>
                    </p>

                    <p class="side-by-side">
                        <label>
                            <uimessage code="pihcore.uterusPalpation" />
                        </label>
                        <obs conceptId="CIEL:167035" style="radio"
                             answerConceptIds="CIEL:167036,CIEL:167037"
                             answerCodes="pihcore.tenderUterus,pihcore.nonSensitiveUterus"/>
                    </p>
                </div>

                <div>
                    <p id="afi" class="side-by-side">
                        <label>
                            <uimessage code="Amniotic fluid index (AFI)"/>
                        </label>
                        <obs conceptId="CIEL:165388" style="radio"
                             answerConceptIds="CIEL:1115,CIEL:162648,CIEL:164471"
                             answerCodes="normal,low,high"/>
                    </p>

                    <p>
                        <label>
                            <uimessage code="Vaginal examination (V/E)"/>
                        </label>
                        <obs conceptId="CIEL:160969" style="text"/>
                    </p>
                </div>

            </div>
        </div>
    </section>

    <section id="diagnosis" sectionTag="fieldset" headerTag="legend" headerStyle="title"
