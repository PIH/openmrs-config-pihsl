<htmlform formUuid="dffa9543-2cf0-4b9e-9306-0aebeb7a1835"
          formName="Family Planning Initial"
          formEncounterType="52fe1a29-678d-49cb-9ccd-7296d634284d"
          formVersion="1.0">

    <postSubmissionAction class="org.openmrs.module.pihcore.htmlformentry.action.ReopenVisitAction"/>

    <style type="text/css">
        <ifMode mode="VIEW" include="false">
            #data-collection {
                display: inline-block;
                width: 58%;
                vertical-align: top;
            }
        </ifMode>
    </style>

    <script type="text/javascript">

        jq(function() {
            // handlers for next and submit buttons, see nextAndSubmitButtons.js
            setUpNextAndSubmitButtons();
        });

    </script>

    <ifMode mode="VIEW" include="false">
        <h2>
            <label>
                <uimessage code="Family Planning Initial"/>
            </label>
        </h2>
    </ifMode>

    <subform path="configuration/pih/subforms/encounter-provider-location-date.xml">
        <span subform-parameter="encounter-location-widget">
            <encounterLocation default="SessionAttribute:emrContext.sessionLocationId"
                               tags="Maternal and Child Location"/>
        </span>
        <span subform-parameter="encounter-provider-widget">
            <encounterProviderAndRole default="currentUser"
                                      encounterRole="4f10ad1a-ec49-48df-98c7-1391c6ac7f05"
                                      providerRoles="${providerGroup.group2}"
                                      required="true"/>
        </span>
    </subform>

    <section id="disability" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Disability">
        <div class="section-container">
            <repeat>
                <template>
                    <obs conceptId="CIEL:162558" style="checkbox"
                         answerConceptId="{concept}" answerCodeXX="{name}"/>
                </template>
                <render concept="PIH:21469"   name="Physical disability" />
                <render concept="CIEL:159298" name="Visual impairment" />
                <render concept="CIEL:112846" name="Speech and language impairment" />
                <render concept="CIEL:139075" name="Hearing impairment" />
                <render concept="CIEL:153343" name="Learning impairment" />
                <render concept="PIH:21470"   name="Multiple" />
            </repeat>
        </div>
    </section>

    <section id="service" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Service type">
        <div class="section-container">
            <repeat>
                <template>
                    <obs conceptId="PIH:13236" style="checkbox"
                         answerConceptId="{concept}" answerCode="{name}"/>
                </template>
                <render concept="CIEL:163494" name="Method switch" />
                <render concept="PIH:14376"   name="Post abortion" />
            </repeat>
            <br/>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="For post-partum family planning" />
                </label>
                <obs conceptId="PIH:21472" style="radio"
                     answerConceptIds="PIH:21473,PIH:21474,PIH:21475" />
            </p>
        </div>
    </section>

    <section id="vitals" sectionTag="fieldset" headerTag="legend"
             headerStyle="title" headerCode="pihcore.vitalSigns">
        <div class="section-container">
            <subform path="configuration/pih/subforms/prior-vital-signs-widget.xml"/>
            <br/>
            <subform path="configuration/pih/subforms/vital-signs-wt-ht-bp-widget.xml"/>
        </div>
    </section>

    <section id="fp-history" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="pihcore.familyPlanningHistory.title">
        <div class="section-container">
            <table>
                <tr>
                    <td>
                    </td>
                    <th>
                        <label>
                            <uimessage code="pihcore.startDate" />
                        </label>
                    </th>
                    <th>
                        <label>
                            <uimessage code="pihcore.endDate" />
                        </label>
                    </th>
                </tr>
                <repeat>
                    <template>
                        <obsgroup groupingConceptId="PIH:Family planning history construct" showIfEmpty="false">
                            <tr>
                                <td id="f{dID}-fp">
                                    <obs conceptId="CIEL:374" answerConceptId="{acID}"
                                         answerCode="{csName}" style="checkbox"
                                         toggle="{id: 'f{dID}-date', style: 'dim'}"/>
                                </td>
                                <td class="f{dID}-date">
                                    <obs conceptId="CIEL:163757" />
                                </td>
                                <td class="f{dID}-date">
                                    <obs conceptId="CIEL:163758" allowFutureDates="true" />
                                </td>
                            </tr>
                        </obsgroup>
                    </template>
                    <render acID="CIEL:104625" dID="104625" csName="Microgynon" />
                    <render acID="CIEL:159783" dID="159783" csName="Other combined oral contraceptive (COC)" />
                    <render acID="CIEL:78796"  dID="78796" csName="Microlut" />
                    <render acID="CIEL:80784"  dID="80784" csName="Other progestin-only pill (POP)" />
                    <render acID="CIEL:190"    dID="190" csName="Condoms" />
                    <render acID="CIEL:907"    dID="907" csName="Depo-provera" />
                    <render acID="PIH:21450"   dID="21450" csName="Sayana press" />
                    <render acID="PIH:21478"   dID="21478"  csName="Copper T IUD" />
                    <render acID="CIEL:165464" dID="165464" csName="Hormonal IUD" />
                    <render acID="CIEL:1873"   dID="1873" csName="Jadelle" />
                    <render acID="CIEL:76022"  dID="76022" csName="Implanon" />
                    <render acID="CIEL:162422" dID="162422" csName="Other implant" />
                    <render acID="CIEL:5277"   dID="5277" csName="pihcore.fp.rhythm" />
                    <render acID="CIEL:136163" dID="136163" csName="Lactation amenorrhea method (LAM)" />

                    <render acID="CIEL:1472" dID="1472" csName="pihcore.fp.tubalLig" />
                    <render acID="CIEL:1489" dID="1489" csName="Vasectomy" />
                </repeat>
            </table>
        </div>
    </section>

    <section id="fp-method" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Family planning method">
        <div class="section-container">
            <div>
                <div>
                    <p class="list-inline-wide">
                        <label>
                            <uimessage code="Family planning counselling"/>
                        </label>
                        <obs conceptId="CIEL:1382" style="radio"
                             answerConceptIds="CIEL:1065,CIEL:1066"
                             answerCodes="yes,no"/>
                    </p>

                    <p class="list-inline-wide">
                        <label>
                            <uimessage code="Accepts and receives family planning"/>
                        </label>
                        <obs id="accepts-fp" conceptId="CIEL:166421" style="radio"
                             answerConceptIds="CIEL:1065,CIEL:1066"
                             answerCodes="yes,no">
                        </obs>
                    </p>
                </div>

                <div class="two-columns">
                    <div id="coc-pop-method">
                        <p>
                            <strong>
                                <uimessage code="Combined oral contraceptive (COC)"/>
                            </strong>

                            <repeat>
                                <template>
                                    <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                        <obs id="fp-meth-{dID}" conceptId="CIEL:374" style="checkbox"
                                             answerConceptId="{acID}"
                                             answerCode="{csName}">
                                        </obs>
                                    </obsgroup>
                                </template>
                                <render acID="CIEL:104625" dID="104625" csName="Microgynon" />
                            </repeat>
                            <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                <obs conceptId="CIEL:374" style="checkbox"
                                     answerConceptId="CIEL:159783"
                                     answerCode="Other combined oral contraceptive (COC)"
                                     showCommentField="true" commentFieldLabel="specify:">
                                </obs>
                            </obsgroup>
                        </p>

                        <p>
                            <strong>
                                <uimessage code="Progestin-only orals"/>
                            </strong>

                            <repeat>
                                <template>
                                    <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                        <obs id="fp-meth-{dID}" conceptId="CIEL:374" style="checkbox"
                                             answerConceptId="{acID}"
                                             answerCode="{csName}">
                                        </obs>
                                    </obsgroup>
                                </template>
                                <render acID="CIEL:78796"  dID="78796" csName="Microlut" />
                            </repeat>
                            <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                <obs conceptId="CIEL:374" style="checkbox"
                                     answerConceptId="CIEL:80784"
                                     answerCode="Other progestin-only pill (POP)"
                                     showCommentField="true" commentFieldLabel="specify:">
                                </obs>
                            </obsgroup>
                        </p>
                    </div>
                    <div id="injectables-iud-method">
                        <p>
                            <strong>
                                <uimessage code="Injectables"/>
                            </strong>

                            <repeat>
                                <template>
                                    <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                        <obs id="fp-meth-{dID}" conceptId="CIEL:374" style="checkbox"
                                             answerConceptId="{acID}"
                                             answerCode="{csName}">
                                        </obs>
                                    </obsgroup>
                                </template>
                                <render acID="CIEL:907"    dID="907" csName="Depo-provera" />
                                <render acID="PIH:21450"   dID="21450" csName="Sayana press" />
                            </repeat>
                            <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                <obs conceptId="CIEL:374" style="checkbox"
                                     answerConceptId="CIEL:5279"
                                     answerCode="Other injectable contraceptive"
                                     showCommentField="true" commentFieldLabel="specify:">
                                </obs>
                            </obsgroup>
                        </p>

                        <p>
                            <strong>
                                <uimessage code="Intrauterine Contraceptive Device (IUCD)"/>
                            </strong>

                            <repeat>
                                <template>
                                    <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                        <obs id="fp-meth-{dID}" conceptId="CIEL:374" style="checkbox"
                                             answerConceptId="{acID}"
                                             answerCode="{csName}">
                                        </obs>
                                    </obsgroup>
                                </template>
                                <render acID="PIH:21478"   dID="21478"  csName="Copper T IUD" />
                                <render acID="CIEL:165464" dID="165464" csName="Hormonal IUD" />
                            </repeat>
                        </p>
                    </div>
                </div>

                <div>
                    <div id="implant-method" class="two-columns">
                        <div>
                            <p>
                                <strong>
                                    <uimessage code="Implants"/>
                                </strong>

                                <repeat>
                                    <template>
                                        <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                            <obs id="fp-meth-{dID}" conceptId="CIEL:374" style="checkbox"
                                                 answerConceptId="{acID}"
                                                 answerCode="{csName}">
                                                <controls>
                                                    <when value="CIEL:1873" thenDisplay="#implant-date"/>
                                                    <when value="CIEL:5275" thenDisplay="#implant-date"/>
                                                </controls>
                                            </obs>
                                        </obsgroup>
                                    </template>
                                    <render acID="CIEL:1873"   dID="1873" csName="Jadelle" />
                                    <render acID="CIEL:76022"  dID="76022" csName="Implanon" />
                                </repeat>
                                <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                    <obs conceptId="CIEL:374" style="checkbox"
                                         answerConceptId="CIEL:162422"
                                         answerCode="Other implant"
                                         showCommentField="true" commentFieldLabel="specify:">
                                    </obs>
                                </obsgroup>
                            </p>
                        </div>

                        <div id="implant-date">
                            <label>
                                <uimessage code="pihcore.dateImplant"/>:
                            </label>
                            <obs conceptId="PIH:3203" />
                        </div>
                    </div>

                    <div id="condom-method">
                        <p>
                            <strong>
                                <uimessage code="Condom"/>
                            </strong>

                            <repeat>
                                <template>
                                    <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                                        <obs id="fp-meth-{dID}" conceptId="CIEL:374" style="checkbox"
                                             answerConceptId="{acID}"
                                             answerCode="{csName}">
                                        </obs>
                                    </obsgroup>
                                </template>
                                <render acID="CIEL:164813" dID="164813" csName="Male condom" />
                                <render acID="CIEL:164814" dID="164814" csName="Female condom" />
                            </repeat>
                        </p>
                    </div>
                </div>


            </div>

            <includeIf velocityTest="$patient.gender == 'F' ">
                <div>
                    <p>
                        <strong>
                            <uimessage code="Other contraceptive methods"/>
                        </strong>
                        <obs conceptId="CIEL:160693" style="checkbox"
                             answerConceptId="CIEL:160570">
                        </obs>
                    </p>
                </div>
            </includeIf>

            <div>
                <p>
                    <strong>
                        <uimessage code="Permanent method"/>
                    </strong>
                    <includeIf velocityTest="$patient.gender == 'F' ">
                        <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                            <obs conceptId="CIEL:374" style="checkbox"
                                 answerConceptId="CIEL:1472">
                            </obs>
                        </obsgroup>
                    </includeIf>
                    <includeIf velocityTest="$patient.gender == 'M' ">
                        <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                            <obs conceptId="CIEL:374" style="checkbox"
                                 answerConceptId="CIEL:1489">
                            </obs>
                        </obsgroup>
                    </includeIf>
                </p>
            </div>

            <div>
                <p>
                    <strong>
                        <uimessage code="Other family planning method"/>
                    </strong>
                    <includeIf velocityTest="$patient.gender == 'F' ">
                        <obsgroup groupingConceptId="PIH:Family planning construct" showIfEmpty="false">
                            <obs conceptId="CIEL:374" style="checkbox"
                                 answerConceptId="CIEL:136163"
                                 answerCode="Lactation amenorrhea method (LAM)" />
                        </obsgroup>
                    </includeIf>
                    <label>
                        <uimessage code="specify other method"/>
                    </label>
                    <obs conceptId="PIH:2996" style="text" />
                </p>
            </div>
        </div>
    </section>

    <section id="additional" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Additional information">
        <div class="section-container">
            <div>
                <p>
                    <label>
                        <uimessage code="Client referred"/>
                    </label>
                    <span class="small">
                        <obs conceptId="PIH:6421" style="text" />
                    </span>
                </p>

                <div>
                    <p>
                        <label>
                            <uimessage code="Date of next appointment"/>
                        </label>
                        <span class="small">
                            <obs id="apptDate"
                                 conceptId="PIH:RETURN VISIT DATE"
                                 allowFutureDates="true" allowPastDates="false" />
                        </span>
                    </p>
                </div>
                <p class="list-inline-wide">
                    <label>
                        <uimessage code="Referred in from CHW/Facility" />
                    </label>
                    <obs conceptId="PIH:2536" style="radio"
                         answerConceptIds="CIEL:1065,CIEL:1066" answerCodes="yes,no" />
                </p>
                <p class="list-inline-wide">
                    <label>
                        <uimessage code="Referred out to other facility" />
                    </label>
                    <obs conceptId="PIH:6547" style="radio"
                         answerConceptIds="CIEL:1065,CIEL:1066" answerCodes="yes,no" />
                </p>
            </div>
        </div>
    </section>

    <ifMode mode="VIEW" include="false">
        <div id="buttons">
            <submit submitClass="confirm right" submitCode="mirebalais.save"/>
            <button type="button" class="cancel">
                <uimessage code="emr.cancel"/>
            </button>
        </div>
    </ifMode>

</htmlform>
