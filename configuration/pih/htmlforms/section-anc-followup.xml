            padding-top: 1.1em; /* fixes text jump on Enter keypress */
        }

        @media print {
            .print-form-datestamps { display: block !important }
            button.cancel, button.submit { display: none }
            label { font-weight: bold }
            label[for] { font-weight: normal } /* refers to the radio set label */
        }

        .side-button input[type="radio"] {
            float: none;
            display: inline-block;
        }

        #vitals fieldset p {
            vertical-align: top;
            display: inline-block;
            float: none;
        }

        #vitals fieldset .left {
            vertical-align: top;
            display: inline-block;
            float: none;
        }

    </style>

    <style type="text/css">
        <ifMode mode="VIEW" include="true">

            #section-anc-followup legend {
                display: none;
            }

            #section-anc-followup fieldset {
                margin: 0px;
                border: 0px;
                padding: 0px;
            }

            #section-anc-followup fieldset h3 {
                font-size: 1em;
                width: 200px;
                display: inline-block;
                margin: 0px;
                margin-right: 10px;
                color: #3E3E3E;
                vertical-align: top;
            }

            #section-anc-followup fieldset p {
                vertical-align: top;
                display: inline-block;
                float: none;
            }

            #section-anc-followup fieldset .left {
                vertical-align: top;
                display: inline-block;
                float: none;
            }

            #section-anc-followup .title {
                display: none;
            }

            #section-anc-followup br {
                display: none;
            }
        </ifMode>
    </style>

    <ifMode mode="VIEW" include="false">

        <script type="text/javascript">
            jq(document).ready(function() {

                // Set up EDD and Gestational Age
                jq("#calculated-edd-and-gestational").hide();
                const lastLMP = '<lookup complexExpression="$fn.formatDate($fn.latestObs('CIEL:1427').getValueDatetime(), 'yyyy-MM-dd')"/>';
                const currentEncounterDate = '<lookup expression="encounter.getEncounterDatetime().getTime()"/>';
                validateEstimatedDeliveryDate("edd", new Date(+currentEncounterDate), '<uimessage code="pihcore.errors.eddField.invalidDate" />');
                eddCannotBeOlderThanTwoWeeks("edd", new Date(+currentEncounterDate), '<uimessage code="pihcore.errors.eddField.twoWeeksOlder" />');
                const msgWeeks = '<uimessage code="pihcore.weeks"/>';
                // SL-1279: Last menstruation date should not be more than 10 months in the past of the encounter date
                if (typeof lastLMP !== "undefined" &amp;&amp; lastLMP !== null &amp;&amp; (lastLMP.length > 0) &amp;&amp; (daysBetweenUTCDates(new Date(lastLMP), new Date(+currentEncounterDate)) &lt; 305)) {
                    const lastPeriodDate = new Date(lastLMP);
                    let yearMonthDay = lastLMP.split('-');
                    if (yearMonthDay.length == 3) {
                        lastPeriodDate.setFullYear(yearMonthDay[0]);
                        lastPeriodDate.setMonth(+yearMonthDay[1] -1); // the month starts from 0 for January
                        lastPeriodDate.setDate(yearMonthDay[2]);
                        lastPeriodDate.setHours(0, 0, 0);
                    }

                    const gestAgeText = calculateGestationalDays(lastPeriodDate, currentEncounterDate, msgWeeks);
                    jq("#calculated-gestational-age-value").text(gestAgeText);
                    const edd = calculateExpectedDeliveryDate(lastPeriodDate);
                    const locale = window.sessionContext.locale || navigator.language;
                    jq("#calculated-edd").text((Intl.DateTimeFormat(locale, { dateStyle: "medium" })).format(edd));
                    jq("#calculated-edd-and-gestational").show();

                    if (!htmlForm.getValueIfLegal("edd.value")) {
                        getField("edd.value").datepicker("setDate", edd);
                    }
                }

                // handlers for next and submit buttons, see nextAndSubmitButtons.js
                setUpNextAndSubmitButtons();
            });
        </script>

    </ifMode>

    <section id="anc-followup" sectionTag="fieldset" headerTag="legend"
             headerStyle="title" headerCode="pihcore.ancFollowup.title">
        <div class="section-container">
            <div class="two-columns">
                <div>
                    <label>
                        <uimessage code="pihcore.mch.dangerSigns"/>
                    </label>
                    <repeat>
                        <template>
                            <obsgroup groupingConceptId="PIH:Visit Diagnoses" showIfEmpty="false">
                                <obs conceptId="PIH:DIAGNOSIS"
                                     answerConceptId="{concept}" answerCode="{name}"
                                     style="checkbox" />
                            </obsgroup>
                        </template>

                        <render concept="CIEL:165193" name="Oedema of hands or face"/>
                        <render concept="PIH:136"     name="Chest pain"/>
                        <render concept="CIEL:150802" name="Abnormal vaginal bleeding"/>
                        <render concept="CIEL:140238" name="Fever"/>
                        <render concept="CIEL:139081" name="Severe headache"/>
                        <render concept="CIEL:113054" name="Seizure"/>
                        <render concept="CIEL:118938" name="Vision problem"/>
                        <render concept="CIEL:122983" name="Vomiting"/>
                        <render concept="CIEL:142412" name="Diarrhoea"/>
                        <render concept="CIEL:118771" name="Dysuria"/> <!-- painful urination -->
                        <render concept="CIEL:122496" name="Dyspnoea"/> <!-- shortness of breathe -->
                        <render concept="CIEL:151"    name="Abdominal pain"/>
                        <render concept="CIEL:153316" name="Premature uterine contractions"/>
                        <render concept="CIEL:148968" name="Amniotic fluid leaking"/>
                        <render concept="CIEL:113377" name="Decreased foetal movements"/>
                    </repeat>
                </div>

                <!-- ToDo:  Is antenatal hemorrhage a danger sign or risk factor -->
                <!--   <render concept="CIEL:228" name="antenatal hemorrhage"/> -->

                <!-- Risk factors for mother -->
                <div>
                    <label>
                        <uimessage code="pihcore.mch.riskFactors"/>
                    </label>

                    <repeat>
                        <template>
                            <obs conceptId="CIEL:160079" style="checkbox"
                                 answerConceptId="{answerId}" answerCode="{hint}"/>
                        </template>
                        <render answerId="CIEL:156650" hint="History of spontaneous abortion" />
                        <render answerId="CIEL:166426" hint="History of retained placenta" />
                        <render answerId="PIH:Eclampsia" hint="Eclampsia"/>
                        <render answerId="PIH:47" hint="Preeclampsia"/>
                        <render answerId="PIH:ANTEPARTUM HEMORRHAGE" hint="Antepartum haemorrhage"/>
                        <render answerId="CIEL:230" hint="Postpartum haemorrhage"/>
                        <render answerId="CIEL:163155" hint="Previous c-section" />

                        <render answerId="CIEL:138405" hint="HIV" answerCode="pihcore.lab.hiv.title" />
                        <render answerId="PIH:HEART DISEASE" hint="Heart disease"/>
                        <render answerId="PIH:DIABETES" hint="Diabetes"/>
                        <render answerId="PIH:HYPERTENSION" hint="Hypertension" />
                        <render answerId="CIEL:115491" hint="Multiple gestation"/>
                        <render answerId="CIEL:130108" hint="Placental abruption"/>
                        <render answerId="CIEL:114127" hint="Placenta praevia"/>
                        <render answerId="CIEL:140399" hint="Foetal death"/>
                        <render answerId="CIEL:115939" hint="Malpresentation of foetus" />
                        <render answerId="CIEL:165088" hint="Victim of GBV" />
                        <render answerId="CIEL:112493" hint="Syphilis" />
                    </repeat>

                    <obs conceptId="CIEL:160079" answerConceptId="PIH:OTHER"
                         commentFieldLabel="  " style="checkbox"/>
                </div>
            </div>

            <br/><br/>
            <div id="calculated-edd-and-gestational" class="two-columns hidden">
                <div>
                    <span id="calculated-edd-wrapper">
                        <span id="calculated-edd-label">
                            <uimessage code="pihcore.calculatedEstimatedDeliveryDate"/>:&#160;
                        </span>
                        <span id='calculated-edd' class="value"></span>
                    </span>
                </div>

                <div>
                    <span id="calculated-gestational-age-wrapper">
                        <span id="calculated-gestational-age-label">
                            <uimessage code="pihcore.calculatedGestationalAge"/>:&#160;
                        </span>
                        <span id='calculated-gestational-age-value' class="value"></span>
                    </span>
                </div>
            </div>
            <br/>

            <div class="two-columns">
              <div>
                  <label>
                      <uimessage code="pihcore.pregnancy.dueDate"/>
                  </label>
              </div>
                <div>
                  <span class="small">
                      <obs id="edd" conceptId="CIEL:5596" allowFutureDates="true" allowPastDates="true"/>
                  </span>
              </div>
            </div>
        </div>
    </section>

    <section id="vitals" sectionTag="fieldset" headerTag="legend"
             headerStyle="title" headerCode="pihcore.vitalSigns">

        <div class="section-container">
            <subform path="configuration/pih/subforms/prior-vital-signs-widget.xml"/>
            <br/>
            <subform path="configuration/pih/subforms/vital-signs-anc-widget.xml"/>
        </div>

    </section>

    <section id="lab-treatment" sectionTag="fieldset" headerTag="legend"
             headerStyle="title" headerCode="Lab and Treatment">
        <div class="section-container side-button">

            <p class="list-inline">
                <label>
                    <uimessage code="pihcore.lab.malariaRDT"/>
                </label>
                <obs id="malariaRDT" style="radio"
                     conceptId="CIEL:1643"
                     answerConceptIds="CIEL:703,CIEL:664,CIEL:1138"/>
            </p>

            <subform path="configuration/pih/subforms/rapid-tests-widget.xml"/>

            <p class="list-inline">
                <label>
                    <uimessage code="pihcore.lab.Sickling.exam"/>
                </label>
                <obs id="sickling" style="radio"
                     conceptId="CIEL:160225"
                     answerConceptIds="CIEL:703,CIEL:664,CIEL:1138"/>
            </p>

            <!-- Urine dipstick -->
            <repeat>
                <template>
                    <p class="list-inline">
                        <label for="urine-{message}">
                            <uimessage code="Urine {message}"/>
                        </label>
                        <obs id="urine-{message}" style="radio"
                             conceptId="CIEL:{concept}"
                             answerConceptIds="{answers}"/>
                    </p>
                </template>
                <render concept="159734" message="glucose" answers="CIEL:1365,CIEL:1364,CIEL:1363,CIEL:1362,CIEL:664" />
                <render concept="1875"   message="protein" answers="CIEL:1365,CIEL:1364,CIEL:1363,CIEL:1362,CIEL:159416,CIEL:664" />
                <render concept="45"     message="hCG" answers="CIEL:703,CIEL:664,CIEL:1138" />
            </repeat>
            <br/>

            <h3>
                <uimessage code="Radiology"/>
            </h3>
            <div class="two-columns">
                <div>
                    <obs id="us-performed" conceptId="PIH:9350" style="checkbox"
                         answerConceptId="PIH:Ultrasound" >
                        <controls>
                            <when value="PIH:Ultrasound" thenDisplay="#us-findings" />
                        </controls>
                    </obs>
                </div>
                <div id="us-findings">
                    <obs conceptId="PIH:7018" style="textarea"
                         labelText="Ultrasound findings" />
                </div>
            </div>
            <br/>

            <h3>Treatment</h3>

            <p class="list-inline-wide">
                <label for="fefol">
                    <uimessage code="FeFol (Ferrous sulfate + Folic acid)"/>
                </label>
                <obs id="fefol" style="radio"
                     conceptId="CIEL:164166"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no"/>
            </p>

            <p class="list-inline-wide">
                <label for="ipt-sp">
                    <uimessage code="IPTp-SP (for malaria)"/>
                </label>
                <obs id="ipt-sp" style="radio"
                     conceptId="CIEL:1591"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no"/>
            </p>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="Nutrition counselling"/>
                </label>
                <obs conceptId="CIEL:1380" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no" />
            </p>

            <p>
                <obs conceptId="PIH:6760" style="textarea" labelText="Other complaints" />
            </p>
        </div>
    </section>

    <section id="diagnosis" sectionTag="fieldset" headerTag="legend"
             headerStyle="title" headerCode="Diagnoses">
        <div class="section-container">
            <div id="data-collection">
                <encounterDiagnosesByObs
                        selectedDiagnosesTarget="#encounter-diagnoses-target"/>
                <p>
                    <label>
                        <uimessage code="emr.consult.freeTextComments"/>
                    </label>
                    <obs conceptId="PIH:CLINICAL IMPRESSION COMMENTS" style="textarea" rows="5"/>
                </p>
            </div>

            <div id="encounter-diagnoses-target">
            </div>
        </div>
    </section>

    <section id="drug-orders" sectionTag="fieldset" headerTag="legend" headerStyle="title" headerCode="pihcore.visitNote.orders.medications">
        <div class="section-container">
            <subform path="configuration/pih/subforms/drug-order-widget.xml"/>
        </div>
    </section>

    <section id="prevention" sectionTag="fieldset" headerTag="legend"
             headerStyle="title" headerCode="Prevention Measures">
        <div class="section-container">

            <repeat>
                <template>
                    <p class="list-inline-wide">
                        <label>
                            <uimessage code="{words}"/>
                        </label>
                        <obs id="{hint}" style="radio"
                             conceptId="CIEL:{cId}"
                             answerConceptIds="CIEL:1065,CIEL:1066"
                             answerCodes="yes,no"/>
                    </p>
                </template>
                <render cId="159855" words="Received LLIN (Long-lasting insecticide net)" hint="bednet"/>
                <render cId="159922" words="Albendazole (deworming)" hint="deworm"/>
                <render cId="1382"   words="Family planning counselling" hint="fp-counsel"/>
            </repeat>
        </div>
    </section>

    <section id="counselling" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Counselling">
        <div class="section-container">
            <p class="list-inline-wide">
                <label>
                    <uimessage code="Counselled for HIV testing"/>
                </label>
                <obs conceptId="PIH:11381" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no"
                     answerSeparator=" " />
            </p>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="Counselled for danger signs"/>
                </label>
                <obs conceptId="CIEL:161050" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no"/>
            </p>
        </div>
    </section>

    <section id="birth-home" sectionTag="fieldset" headerTag="legend"
             headerStyle="title" headerCode="Birth waiting home">
        <div class="section-container">
            <p>
                <label>
                    <uimessage code="Currently staying at birth waiting home" />
                </label>
                <obs conceptId="PIH:20930" style="checkbox"
                     answerConceptId="PIH:12366" />
            </p>
        </div>
    </section>

    <section id="return" sectionTag="fieldset" headerTag="legend"
             headerStyle="title" headerCode="Return visit">
        <div class="section-container two-columns">
            <div id="disposition">
                <encounterDisposition id="encounter-disposition" />
            </div>
            <div>
                <p>
                    <label>
                        <uimessage code="pihcore.consult.returnVisitDate"/>
                    </label>
                    <span class="small">
                        <obs id="apptDate"
                             conceptId="PIH:RETURN VISIT DATE"
                             allowFutureDates="true" allowPastDates="false" />
                    </span>
                </p>
            </div>
        </div>
    </section>

    <ifMode mode="VIEW" include="false">
        <div id="buttons">
            <button id="next" type="button" class="submitButton confirm right"><uimessage code="emr.next"/><i class="icon-spinner icon-spin icon-2x" style="display: none; margin-left: 10px;"></i></button>
            <button id="submit" class="submitButton confirm right"><uimessage code="mirebalais.save"/><i class="icon-spinner icon-spin icon-2x" style="display: none; margin-left: 10px;"></i></button>
            <button id="cancel" type="button" class="cancel"><uimessage code="emr.cancel"/></button>
        </div>
    </ifMode>

</htmlform>
