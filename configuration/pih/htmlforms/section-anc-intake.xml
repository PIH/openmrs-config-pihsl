    <ifMode mode="VIEW" include="false" >
        <script type="text/javascript">

            jq(function() {             
                var encounterDate = '<lookup expression="encounter.getEncounterDatetime().getTime()" />';
                setUpEdd(encounterDate,'<uimessage code="pihcore.weeks" />');
                validateEstimatedDeliveryDate("lastPeriodDate", new Date(+encounterDate), '<uimessage code="pihcore.errors.lastPeriodDateField.invalidDate" />');
                validateEstimatedDeliveryDate("edd", new Date(+encounterDate), '<uimessage code="pihcore.errors.eddField.invalidDate" />');
                eddCannotBeOlderThanTwoWeeks("edd", new Date(+encounterDate), '<uimessage code="pihcore.errors.eddField.twoWeeksOlder" />');

                // handlers for next and submit buttons, see nextAndSubmitButtons.js
                setUpNextAndSubmitButtons();

                htmlForm.getBeforeValidation().push(function() {
                    //SL-1279, Last menstruation date should not be more than 10 months in the past of the encounter date
                    const lastPeriodElem = jq("#lastPeriodDate input[type='hidden']");
                    if ( lastPeriodElem ) {
                        const lastPeriodVal = lastPeriodElem.val();
                        if ( lastPeriodVal ) {
                            if ( daysBetweenUTCDates(new Date(lastPeriodVal), new Date(+encounterDate)) &gt; 305 ) {
                                jq(window).scrollTop(jq("#lastPeriodDate").offset().top - 100);
                                return false;
                            }
                        }
                    }
                    return true;
                });
            });
        </script>
    </ifMode>

    <script type="text/javascript">

        jq(document).ready(function() {
            let currentEncounterDate = new Date();
            let lookupEncDate = '<lookup expression="encounter.getEncounterDatetime().getTime()"/>';
            if ( lookupEncDate ) {
                currentEncounterDate = new Date(+lookupEncDate);
            }

            jq("#edd input[type='hidden']").change(function() {
                // When the last menstrual period date is present, the gestational age is derived
                // from it elsewhere; do not calculate or display a gestational age based on the EDD.
                const lastPeriodVal = jq("#lastPeriodDate input[type='hidden']").val();
                if ( lastPeriodVal ) {
                    return;
                }
                const estimatedDelivery = this.value;
                const estimatedDeliveryDate = new Date(estimatedDelivery);
                if ( estimatedDeliveryDate.getTime() &gt; currentEncounterDate.getTime() ) {
                    // the estimated gestational age only makes sense if EDD is after the encounter time
                    // Compute gestational age in days first (40 weeks = 280 days), then format as
                    // weeks.days, mirroring calculateGestationalDays() in mch.js so that the value
                    // matches the one derived from the last menstrual period date.
                    const daysRemaining = daysBetweenUTCDates(estimatedDeliveryDate, currentEncounterDate);
                    const gestAgeDays = 280 - daysRemaining;
                    // UHM-9364: do not display/store negative gestational age values
                    if (gestAgeDays > 0) {
                        const gestAgeWeeks = Math.floor(gestAgeDays / 7);
                        const gestAgeRemainderDays = gestAgeDays % 7;
                        const estGestAge = (gestAgeWeeks + (gestAgeRemainderDays ? gestAgeRemainderDays / 10 : 0)).toFixed(1);
                        jq(".gestationalAge input[type='text']").val(estGestAge);
                    } else {
                        jq(".gestationalAge input[type='text']").val('');
                    }
                }
            });

            jq(".gestationalAge input[type='text']").change(function() {
                const numValue = Number(this.value);
                if (isNaN(numValue)) {
                    console.error("Gestational age must be a valid number");
                    return;
                }
                // The gestational age is stored in weeks.days notation (e.g. 25.5 = 25 weeks 5 days),
                // so convert it to days before computing days remaining, to stay consistent with the
                // EDD -> gestational age calculation above.
                const gestAgeWeeks = Math.floor(numValue);
                const gestAgeRemainderDays = Math.round((numValue - gestAgeWeeks) * 10);
                const gestAgeDays = gestAgeWeeks * 7 + gestAgeRemainderDays;
                // EDD = encounter date + days remaining until 40 weeks (280 days) is reached
                const daysRemaining = 280 - gestAgeDays;
                const newEdd = new Date(currentEncounterDate.getTime() + daysRemaining * 24 * 60 * 60 * 1000);
                getField("edd.value").datepicker("setDate", newEdd);
            });
        });
    </script>

