    <ifMode mode="VIEW" include="false">
        <script type="text/javascript">

            function updateTotalScore(individualScore, totalScore) {
                let total = 0;

                jq("." + individualScore + " span input").each(function() {
                    const raw = jq(this).val();

                    if (raw === null || raw === undefined || raw === "") return;

                    const n = Number(raw);
                    if (Number.isFinite(n)) total += n;
                });

                jq("#" + totalScore).find("input").val(total);
            }

            function selectScore(signId, score, element) {
                const row = element.closest('tr');
                // clear previous highlights in this row (optional but usually desired)
                jq(row).find('td.clickable-td').css('background-color', '');
                // highlight the clicked cell
                jq(element).css('background-color', '#fff3e0');
                jq("#" + signId + "-score input").val(score);
                const parentTable = element.closest('table');
                if (parentTable) {
                    const tableId = jq(parentTable).attr("id");
                    updateTotalScore(tableId + "-input" , "total-" + tableId);
                }

            }
            jq(document).ready(function() {
                jq(".neuro-score-input span input").attr("readonly", "readonly");
                jq("#total-neuro-score").find("input").attr("readonly", "readonly");
                jq(".mat-score-input span input").attr("readonly", "readonly");
                jq("#total-mat-score").find("input").attr("readonly", "readonly");
                updateTotalScore();
            });

        </script>

    </ifMode>

