<htmlform formUuid="6a25ba50-cba6-44c2-a132-9fad31e01f17"
          formName="Cervical Cancer Screening"
          formEncounterType="820a80b0-1d59-407e-acbb-56abb69abd35"
          formVersion="1.0">

    <postSubmissionAction class="org.openmrs.module.pihcore.htmlformentry.action.ApplyDispositionAction"/>
    <postSubmissionAction class="org.openmrs.module.pihcore.htmlformentry.action.CleanDiagnosisConstructAction" />

    <macros>
        <macro key="imageBase" value="/openmrs/ms/uiframework/resource/file/configuration/pih/htmlforms/images"/>
    </macros>

    <style type="text/css">
        .narrow {
            width: 200px;
        }

        <ifMode mode="VIEW" include="false">
            #data-collection {
                display: inline-block;
                width: 58%;
                vertical-align: top;
            }

        </ifMode>

    </style>

    <script type="text/javascript">

        jq(function() {
            // handlers for next and submit buttons, see nextAndSubmitButtons.js
            setUpNextAndSubmitButtons();
        });

    </script>

    <ifMode mode="VIEW" include="false">
        <h2>
            <label>
                <uimessage code="Cervical Cancer Screening"/>
            </label>
        </h2>
    </ifMode>

    <subform path="configuration/pih/subforms/encounter-provider-location-date.xml">
        <span subform-parameter="encounter-location-widget">
            <encounterLocation default="SessionAttribute:emrContext.sessionLocationId"
                               tags="Maternal and Child Location"/>
        </span>
        <span subform-parameter="encounter-provider-widget">
            <encounterProviderAndRole default="currentUser"
                                      encounterRole="4f10ad1a-ec49-48df-98c7-1391c6ac7f05"
                                      providerRoles="${providerGroup.group2}"
                                      required="true"/>
        </span>
    </subform>

    <section id="vitals" sectionTag="fieldset" headerTag="legend"
             headerStyle="title" headerCode="pihcore.vitalSigns">
        <div class="section-container">
            <subform path="configuration/pih/subforms/prior-vital-signs-widget.xml"/>
        </div>
    </section>

    <section id="rep-history" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Reproductive health history">
        <div class="section-container">
            <p class="narrow">
                <label>
                    <uimessage code="pihcore.mch.para" />
                </label>
                <obs conceptId="CIEL:1053" width="4" required="false" id="paraInput" />
            </p>

            <p>
                <label>
                    <uimessage code="Last menstrual period (LMP)" />
                </label>
                <obs conceptId="CIEL:1427" required="false" id="lmp" />
            </p>
            <br/>

            <p>
                <label>
                    <uimessage code="FP method" />
                </label>
                <repeat>
                    <template>
                        <obsgroup groupingConceptId="PIH:Family planning history construct" showIfEmpty="false">
                                    <obs conceptId="CIEL:374" answerConceptId="{acID}"
                                         answerCode="{csName}" style="checkbox"/>
                        </obsgroup>
                    </template>
                    <render acID="CIEL:104625" dID="104625" csName="Microgynon" />
                    <render acID="CIEL:159783" dID="159783" csName="Other combined oral contraceptive (COC)" />
                    <render acID="CIEL:78796"  dID="78796" csName="Microlut" />
                    <render acID="CIEL:80784"  dID="80784" csName="Other progestin-only pill (POP)" />
                    <render acID="CIEL:190"    dID="190" csName="Condoms" />
                    <render acID="CIEL:907"    dID="907" csName="Depo-provera" />
                    <render acID="PIH:21450"   dID="21450" csName="Sayana press" />
                    <render acID="PIH:21478"   dID="21478"  csName="Copper T IUD" />
                    <render acID="CIEL:165464" dID="165464" csName="Hormonal IUD" />
                    <render acID="CIEL:1873"   dID="1873" csName="Jadelle" />
                    <render acID="CIEL:76022"  dID="76022" csName="Implanon" />
                    <render acID="CIEL:162422" dID="162422" csName="Other implant" />
                    <render acID="CIEL:5277"   dID="5277" csName="pihcore.fp.rhythm" />
                    <render acID="CIEL:136163" dID="136163" csName="Lactation amenorrhea method (LAM)" />

                    <render acID="CIEL:1472" dID="1472" csName="pihcore.fp.tubalLig" />
                    <render acID="CIEL:1489" dID="1489" csName="Vasectomy" />
                </repeat>
            </p>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="Abnormal vaginal bleeding?" />
                </label>
                <obs conceptId="CIEL:150802" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no"/>
            </p>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="Screened for cervical cancer before?" />
                </label>
                <obs conceptId="PIH:21485" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no"/>
            </p>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="Current abnormal PV discharge?" />
                </label>
                <obs conceptId="PIH:21486" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no"/>
            </p>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="History of STD?" />
                </label>
                <obs conceptId="CIEL:156660" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no"/>
            </p>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="Age at first coitus" />
                </label>
                <obs conceptId="PIH:21487" style="radio"
                     answerConceptIds="PIH:21488,PIH:21489"
                     answerCodes="less than 15,above 15 years old" />
            </p>

            <p class="narrow">
                <label>
                    <uimessage code="Age at first birth" />
                </label>
                <obs conceptId="CIEL:160339" showUnits="true"/>
            </p>


            <p class="list-inline-wide">
                <label>
                    <uimessage code="Cigarette smoking?" />
                </label>
                <obs conceptId="CIEL:163731" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no"/>
            </p>

            <p>
                <label>
                    <uimessage code="Other OB/Gynecology history" />
                </label>

                <!-- Diagnosis history -->
                <repeat>
                    <template>
                        <!-- Dysmenorrhea -->
                        <obsgroup groupingConceptId="PIH:Visit Diagnoses" showIfEmpty="false">
                            <obs conceptId="PIH:DIAGNOSIS" style="checkbox" answerConceptId="{dxId}" />
                        </obsgroup>
                    </template>
                    <render dxId="CIEL:127" msg="dysmenorrhea" />
                    <render dxId="CIEL:113814" msg="previous c-section" />

                </repeat>

                <obs conceptId="CIEL:160221" style="textarea" />
            </p>
        </div>
    </section>

    <section id="hiv-status" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="HIV status">
        <div class="section-container">
            <p class="list-inline-wide">
                <label>
                    <uimessage code="HIV Status" />
                </label>
                <obs conceptId="PIH:3753" style="radio"
                     answerConceptIds="CIEL:703,CIEL:664,CIEL:1067"
                     answerCodes="positive,negative,unknown" />
            </p>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="ART Status" />
                </label>
                <obs conceptId="CIEL:160119" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="on ART,not on ART" />
            </p>

            <p class="list-inline-wide">
                <label>
                    <uimessage code="HCT accepted" />
                </label>
                <obs conceptId="CIEL:165328" style="radio"
                     answerConceptIds="CIEL:1065,CIEL:1066"
                     answerCodes="yes,no" />
            </p>
        </div>
    </section>

    <section id="physical-exam" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Physical exam">
        <div id="gynecology" class="section-container">
            <h3>
                <uimessage code="pihcore.exam.gynecology_exam.title"/>
            </h3>

            <div class="two-columns exam">
                <div>
                    <repeat>
                        <template>
                            <p>
                                <obs class="{switch}" conceptId="PIH:13229"
                                     answerConceptId="{finding}" style="checkbox"/>
                            </p>
                        </template>
                        <render finding="CIEL:1115" name="Normal" switch="normalObs"/>
                        <render finding="CIEL:146512" name="GenCandid" switch="abnormalObs"/>
                        <render finding="CIEL:120147" name="Condyloma" switch="abnormalObs"/>
                        <render finding="CIEL:118784" name="CervDyspl" switch="abnormalObs"/>
                        <render finding="CIEL:165162" name="BadSmell" switch="abnormalObs"/>
                    </repeat>

                    <repeat>
                        <template>
                            <p>
                                <obs class="{switch}" conceptId="PIH:13229"
                                     answerConceptId="{finding}" answerCode="pihcore.specExam.{name}"
                                     style="checkbox"/>
                            </p>
                        </template>
                        <render finding="CIEL:116995" name="cervicitis" switch="abnormalObs"/>
                    </repeat>

                    <repeat>
                        <template>
                            <p>
                                <obs class="{switch}" conceptId="PIH:13229"
                                     answerConceptId="{finding}" style="checkbox"/>
                            </p>
                        </template>
                        <render finding="CIEL:147967" name="Bartholini" switch="abnormalObs"/>
                        <render finding="CIEL:864" name="GenUlcer" switch="abnormalObs"/>
                    </repeat>

                    <p>
                        <obs class="abnormalObs" conceptId="PIH:13229"
                             answerConceptId="CIEL:5622" style="checkbox" showCommentField="true" commentFieldLabel=""/>
                    </p>
                </div>
                <div>
                    <label>
                        <uimessage code="pihcore.via.long"/>
                    </label>
                    <p class="in-line">
                        <obs conceptId="CIEL:162816" style="radio"
                             answerConceptIds="CIEL:1115,CIEL:164808,CIEL:116031"
                             answerSeparator=""/>
                    </p>

                    <!-- Cryotherapy of lesion of cervix -->
                    <p>
                        <obsgroup groupingConceptId="CIEL:1938" showIfEmpty="false">
                            <span class="small hidden">
                                <!-- NOTE: Using 6 so it doesn't conflict with the other procedures -->
                                <obs conceptId="CIEL:1937" defaultValue="6"></obs>
                            </span>
                            <obs conceptId="CIEL:1651" style="checkbox"
                                 answerConceptId="CIEL:162812"/>
                        </obsgroup>
                    </p>

                    <p>
                        <!-- PAP test performed -->
                        <obs conceptId="CIEL:163952" style="checkbox"
                             answerConceptId="CIEL:1267"
                             answerCode="pihcore.papTestPerformed"/>
                    </p>

                    <p class="list-inline">
                        <label>
                            <uimessage code="pihcore.stiSuspected"/>?
                        </label>
                        <obs id="susp-sti" conceptId="CIEL:161558" style="radio"
                             answerConceptIds="CIEL:1065,CIEL:1066" >
                            <controls>
                                <when value="CIEL:1065" thenDisplay="#sti-list" />
                            </controls>
                        </obs>
                    </p>

                    <div id="sti-list">
                        <repeat>
                            <template>
                                <p>
                                    <obs class="{switch}" conceptId="PIH:14365"
                                         answerConceptId="{finding}"
                                         style="checkbox"/>
                                </p>
                            </template>
                            <render finding="CIEL:120733" name="Chlamydia"/>
                            <render finding="CIEL:117767" name="Gonorrhea"/>
                            <render finding="CIEL:117829" name="Genital herpes"/>
                            <render finding="CIEL:111759" name="hepB"/>
                            <render finding="CIEL:1213"   name="HPV"/>
                            <render finding="CIEL:117146" name="Trichomoniasis"/>
                            <render finding="CIEL:148002" name="Bacterial vaginosis (BV)"/>
                        </repeat>
                    </div>

                    <p class="comment-label">
                        <uimessage code="pihcore.exam.comment"/>
                    </p>

                    <p class="comment-field">
                        <obs conceptId="PIH:13231" rows="4" cols="45"/>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section id="diagnosis" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Diagnosis">
        <div class="section-container">

            <div id="data-collection">
                <encounterDiagnosesByObs selectedDiagnosesTarget="#encounter-diagnoses-target"/>
            </div>

            <div id="encounter-diagnoses-target">
            </div>
        </div>
    </section>

    <section id="rapid-tests" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Laboratory tests">
        <div class="section-container">
            <h3>
                <uimessage code="Rapid Tests" />
            </h3>
            <subform path="configuration/pih/subforms/rapid-tests-widget.xml"/>
            <br/><br/>

            <h3>
                <uimessage code="Lab Orders" />
            </h3>
            <pihLabOrder />
        </div>
    </section>

    <section id="integrated-serve" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Integrated services">
        <div class="section-container two-columns">
            <div>
                <label>
                    <uimessage code="Clinical breast exam (CBE)"/>
                </label>
                <p class="in-line">
                    <obs conceptId="PIH:14180" style="radio"
                         answerConceptIds="CIEL:1267,CIEL:1118,CIEL:1067"
                         answerSeparator=""/>
                </p>
            </div>
            <div>
                <obs conceptId="PIH:21595" style="text"
                     labelText="Other integrated services"/>
            </div>
        </div>
    </section>

    <section id="quads" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Visual inspection with acetic acid">
        <div class="section-container two-columns">
            <div>
                <label>
                    <uimessage code="Quadrants involved" />
                </label>
                <repeat>
                    <template>
                        <obs conceptId="PIH:21500" style="checkbox"
                             answer="{quad}" answerLabel="Q{quad}" />
                    </template>
                    <render quad="1" />
                    <render quad="2" />
                    <render quad="3" />
                    <render quad="4" />
                </repeat>
            </div>
            <div>
                <img alt="Cervix_quadrants" style="width: 50%; height: auto;"
                     src="$imageBase/CervixQuadrants.gif" />
            </div>
        </div>
    </section>

    <section id="via-test" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="VIA test results">
        <div class="section-container">
            <div>
                <label>
                    <uimessage code="Screening results"/>
                </label>
                <p class="in-line">
                    <obs conceptId="CIEL:162816" style="radio"
                         answerConceptIds="CIEL:664,CIEL:703,CIEL:167159"
                         answerCodes="VIA negative,VIA positive,Suspect cancer"
                         answerSeparator=""/>
                </p>
            </div>
        </div>
    </section>

    <section id="treatment-consent" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Treatment consent form">
        <div class="section-container">
            <p>
                I hereby agree and consent to the procedure cryotherapy to be performed on me,
                the nature of which has been explained to me. I understand that an assurance
                has been given that the procedure will be performed by a particular person.
                I have also been informed what I need to care for myself after the procedure.
            </p>
        </div>
    </section>

    <section id="treatment-rx" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Treatment and prescriptions">
        <div class="section-container">
            <h2>
               <uimessage code="pihcore.visitNote.orders.medications" />
            </h2>
            <subform path="configuration/pih/subforms/drug-order-widget.xml"/>
        </div>
    </section>

    <section id="referral-section" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Referral and reason">
        <div class="section-container">
            <div class="two-columns">
                <div id="disposition">
                    <encounterDisposition id="encounter-disposition" />
                </div>
            </div>
            <div>
                <p class="side-by-side">
                    <label>
                        <uimessage code="Followup clinic:"/>
                    </label>
                    <br/>
                    <!-- ToDo:  radio or checkboxes?  Update answers -->
                    <obs conceptId="CIEL:1272" style="radio"
                         answerConceptIds="PIH:7831,PIH:FAMILY PLANNING SERVICES,PIH:MENTAL HEALTH SERVICES,CIEL:5622"
                         answerSeparator="&lt;br /&gt;" />
                </p>
            </div>
        </div>
    </section>

    <section id="disposition-section" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Notes, Recommendations, Followup dates">
        <div class="section-container">
            <div class="two-columns">
                <div>
                    <p>
                        <label>
                            <uimessage code="Next appointment date"/>
                        </label>
                        <obs conceptId="PIH:RETURN VISIT DATE" allowFutureDates="true" allowPastDates="false" id="apptDate" required="false"/>
                    </p>
                </div>
                <div>

                </div>
            </div>
        </div>
    </section>

    <ifMode mode="VIEW" include="false">
        <div id="buttons">
            <submit submitClass="confirm right" submitCode="mirebalais.save"/>
            <button type="button" class="cancel">
                <uimessage code="emr.cancel"/>
            </button>
        </div>
    </ifMode>

</htmlform>
