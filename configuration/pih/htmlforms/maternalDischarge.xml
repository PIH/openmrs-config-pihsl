<htmlform id="maternal-discharge"
          formUuid="ccd256b4-a861-4ec2-88f8-6d56927a09b2"
          htmlformUuid="e299d169-e3ed-42bd-b560-1f5137d72c4d"
          formName="Maternal Discharge"
          formEncounterType="2110a810-db62-4914-ba95-604b96010164" formVersion="1.1">

    <postSubmissionAction class="org.openmrs.module.pihcore.htmlformentry.action.ApplyDispositionAction"/>
    <postSubmissionAction class="org.openmrs.module.pihcore.htmlformentry.action.PregnancyProgramPostpartumTransitionAction"/>

    <style type="text/css">

        #save-and-print-button {
            margin-top: 5px;
        }
        
        <ifMode mode="VIEW" include="true">

            #maternal-discharge legend {
                display: none;
            }

            #maternal-discharge fieldset {
                margin: 0px;
                border: 0px;
                padding: 0px;
            }

            #maternal-discharge fieldset h3 {
                font-size: 1em;
                width: 200px;
                display: inline-block;
                margin: 0px;
                margin-right: 10px;
                color: #3E3E3E;
                vertical-align: top;
            }

            #maternal-discharge fieldset p {
                vertical-align: top;
                float: none;
            }

            #maternal-discharge fieldset .left {
                vertical-align: top;
                display: inline-block;
                float: none;
            }

            #maternal-discharge .title {
                display: none;
            }

            #maternal-discharge .encounter-date {
                display: none;
            }

            #maternal-discharge .encounter-provider {
                display: none;
            }

            #maternal-discharge .encounter-location {
                display: none;
            }

            #maternal-discharge .comment-label {
                display: none;
            }

            #maternal-discharge .comment-field {
                display: block;
                margin-left: 215px;
            }

            #maternal-discharge br {
                display: none;
            }
        </ifMode>
    </style>

    <div class="print-form-datestamps" style="display:none">
        <p><uimessage code="pihcore.form.created_on"/>:
            <lookup complexExpression="$form.dateCreated"/>
        </p>
        <p><uimessage code="pihcore.form.last_updated_on"/>:
            <lookup complexExpression="$form.dateChanged"/>
        </p>
        <p><uimessage code="pihcore.form.printed_on"/>:
            <lookup complexExpression="$formGeneratedDatetime"/>
        </p>
    </div>

    <ifMode mode="VIEW" include="false">
        <h2>
            <label>
                <uimessage code="pih.task.maternalDischarge"/>
            </label>
        </h2>
    </ifMode>

    <subform path="configuration/pih/subforms/encounter-provider-location-date.xml">
        <span subform-parameter="encounter-location-widget">
            <encounterLocation default="SessionAttribute:emrContext.sessionLocationId" tags="Maternal Discharge Location"/>
        </span>
        <span subform-parameter="encounter-provider-widget">
            <encounterProviderAndRole default="currentUser"
                                      encounterRole="4f10ad1a-ec49-48df-98c7-1391c6ac7f05"
                                      providerRoles="${providerGroup.group1}"
                                      required="true"/>
        </span>
    </subform>

    <ifMode mode="VIEW" include="false">
        <includeIf velocityTest="($fn.latestObsBeforeCurrentEncounter('CIEL:1640', true)) ">
            <section id="Overview" sectionTag="fieldset" headerTag="legend" headerStyle="title"
                     headerCode="Overview">
                <div class="section-container">
                    <p id="when" class="date-one-line">
                            <label>
                                <uimessage code="Date &amp; time of admission"/>
                            </label>
                            <!-- ToDo:  Show date AND time -->
                            <lookup expression="fn.latestObsBeforeCurrentEncounter('CIEL:1640', true).valueDatetime" format="dd MMM yyyy h:mm aa"/>
                    </p>
                </div>
            </section>
        </includeIf>
    </ifMode>

    <style type="text/css">
        <ifMode mode="VIEW" include="false">
            #data-collection {
                display: inline-block;
                width: 50%;
                vertical-align: top;
            }

            #encounter-diagnoses-target {
                display: inline-block;
                width: 45%;
                vertical-align: top;
            }

            #encounter-diagnoses-app {
                margin-bottom: 20px;
            }
        </ifMode>
    </style>

    <section id="diagnosis" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Diagnosis">
        <div class="section-container">

            <div id="data-collection">
                <encounterDiagnosesByObs selectedDiagnosesTarget="#encounter-diagnoses-target"/>
            </div>

            <div id="encounter-diagnoses-target">
            </div>
        </div>
    </section>

    <section id="history" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Clinical History">
        <div class="section-container">
            <obs conceptId="CIEL:160221" style="textarea" />
        </div>
    </section>

    <section id="test-summary" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Test summary">
        <div class="section-container">
            <label>
                <uimessage code="Summary of investigation done and results" />
            </label>
            <obs conceptId="CIEL:165399" style="textarea" />
        </div>
    </section>

    <section id="hospital-mgmt" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="Hospital summary">
        <div class="section-container">
            <label>
                <uimessage code="Summary of management in the hospital" />
            </label>
            <obs conceptId="CIEL:165399" style="textarea" />
        </div>
    </section>

    <section id="drug-orders" sectionTag="fieldset"
             headerTag="legend" headerStyle="title" headerCode="pihcore.visitNote.orders.medications">
        <div class="section-container">
            <subform path="configuration/pih/subforms/drug-order-widget.xml"/>
        </div>
    </section>

    <section id="disposition-section" sectionTag="fieldset" headerTag="legend" headerStyle="title"
             headerCode="coreapps.consult.disposition">
        <div class="section-container">
            <div class="two-columns">
                <div>
                    <div id="disposition">
                        <encounterDisposition required="true" id="encounter-disposition" />
                    </div>
                    <p>
                        <label>
                            <uimessage code="Discharge recommendation" />
                        </label>
                        <obs conceptId="PIH:DISPOSITION COMMENTS" style="textarea"/>
                    </p>
                </div>
                <div>
                    <h4>
                        <uimessage code="Next appointment date"/>
                    </h4>
                    <ifMode mode="VIEW" include="true">
                        <p><string><uimessage code="pihcore.appointment.viewEditMessage" /></string>
                        <a href="/openmrs/spa/home/appointments"><uimessage code="pihcore.appointment.viewAppointments" /></a></p>
                    </ifMode>
                    <scheduleAppointment optional="true" type="scheduled"
                                    locationTag="Appointment Location"
                                    appointmentUuidConcept="PIH:Appointment uuid"
                                    specialities="maternal,other"
                                    sortServicesBy="specialityOrder,serviceName"/>

                </div>

            </div>
        </div>

    </section>

    <ifMode mode="VIEW" include="false">
        <div id="buttons">
            <!-- "Save and Print" floats right and is rendered before Save so, with both floated
                 right, it ends up immediately to the right of Save. It reuses the "confirm" class
                 so it is the same size and colour as the Save button. -->
            <button id="save-and-print-button" type="button" class="confirm right">Save&amp;Print</button>
            <submit submitClass="confirm right" submitCode="mirebalais.save"/>
            <button type="button" class="cancel">
                <uimessage code="emr.cancel"/>
            </button>
        </div>

        <script type="text/javascript">
            jq(function() {
                // Tracks whether the current submission was triggered by "Save&amp;Print"
                // (as opposed to the plain "Save" button).
                var printAfterSave = false;

                // A plain "Save" must never auto-print, so clear the flag if it is clicked.
                jq('#buttons .submitButton').on('click', function() {
                    printAfterSave = false;
                });

                // "Save&amp;Print" performs the normal save, but first records that the form
                // should be printed once we land back on the visit page.
                jq('#save-and-print-button').on('click', function() {
                    printAfterSave = true;
                    submitHtmlForm();
                });

                // Just before the form is actually submitted, encode the print intent into the
                // return URL. After the encounter is saved, htmlForm.js appends the new
                // encounterId and navigates to this URL (the visit page); the "printForm=true"
                // flag tells the visit page to automatically send the saved form to the printer.
                // We run this on every submission (rather than at click time) so that a
                // re-submit after a validation error still reflects the button last clicked.
                beforeSubmit.push(function() {
                    var url = htmlForm.getReturnUrl();
                    if (url) {
                        // drop any flag left over from a previous attempt so it never accumulates
                        url = url.replace(/([?&amp;])printForm=true(&amp;|$)/, function(match, sep, tail) {
                            return tail === '&amp;' ? sep : (sep === '?' ? '?' : '');
                        });
                        if (printAfterSave) {
                            url += (url.indexOf('?') === -1 ? '?' : '&amp;') + 'printForm=true';
                        }
                        htmlForm.setReturnUrl(url);
                    }
                    return true;
                });
            });
        </script>
    </ifMode>

</htmlform>
